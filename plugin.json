{
    "id": "screenkey",
    "name": "Screenkey",
    "description": "Displays keystrokes on screen in a readable format for tutorials",
    "version": "1.0.1",
    "author": "Loc Huynh",
    "type": "widget",
    "icon": "keyboard",
    "capabilities": [
        "control-center"
    ],
    "component": "./ScreenkeyWidget.qml",
    "settings": "./ScreenkeySettings.qml",
    "requires_dms": ">=1.5.0",
    "permissions": [
        "settings_read",
        "settings_write",
        "shell_execute"
    ]
}
